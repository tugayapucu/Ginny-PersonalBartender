# Copy this file to backend/.env and fill in the values before running the backend.
# Never commit backend/.env — it contains secrets.

# HS256 signing key used to sign JWT tokens.
# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
GINNY_SECRET_KEY=change-me-before-deploying

# Comma-separated list of origins the backend will accept CORS requests from.
# For local development the Vite dev server defaults are already allowed,
# so this variable can be omitted entirely in that case.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# How long a JWT token remains valid, in minutes. Defaults to 60.
ACCESS_TOKEN_EXPIRE_MINUTES=60
